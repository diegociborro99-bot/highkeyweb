:{$PORT:8080}

root * /srv
encode zstd gzip
file_server

# Seguridad
header {
	X-Content-Type-Options nosniff
	X-Frame-Options DENY
	Referrer-Policy strict-origin-when-cross-origin
	Strict-Transport-Security "max-age=31536000; includeSubDomains"
	Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
	Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; form-action 'self' https://formsubmit.co; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; upgrade-insecure-requests"
}

# Caché: larga e inmutable para assets que no cambian; corta para HTML y CSS/JS sin hash
@immutable path *.png *.svg *.jpg *.webp *.ico *.mp4 *.woff2
header @immutable Cache-Control "public, max-age=31536000, immutable"
@code path *.css *.js
header @code Cache-Control "no-cache"
@html path / *.html
header @html Cache-Control "no-cache"
